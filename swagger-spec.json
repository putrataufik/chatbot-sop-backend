  "info": {
    "title": "Chatbot SOP API",
    "description": "REST API untuk Chatbot SOP berbasis Recursive Language Model",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Putra Taufik"
          },
          "email": {
            "type": "string",
            "example": "putra@email.com"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 6
          },
          "role": {
            "type": "string",
            "enum": [
              "USER",
              "ADMIN"
            ],
            "example": "USER"
          }
        },
        "required": [
          "name",
          "email",
          "password",
          "role"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "putra@email.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Putra Taufik"
          },
          "role": {
            "type": "string",
            "enum": [
              "USER",
              "ADMIN"
            ]
          },
          "admin_level": {
            "type": "number",
            "example": 1
          },
          "password": {
            "type": "string",
            "example": "newpassword123",
            "minLength": 6
          }
        }
      },
      "CreateSessionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Konsultasi SOP Pengajuan Cuti"
          }
        },
        "required": [
          "title"
        ]
      },
      "SendMessageDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "example": "Bagaimana prosedur pengajuan cuti tahunan?"
          }
        },
        "required": [
          "content"
        ]
      }
    }
  }
}