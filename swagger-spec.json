    "/api/chatbot-sop/sop-documents/bulk": {
      "post": {
        "description": "Title otomatis diambil dari nama file. Format otomatis dideteksi dari ekstensi (.pdf / .txt).",
        "operationId": "SopDocumentsController_createBulk",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    },
                    "description": "Upload multiple file PDF atau TXT sekaligus"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Hasil upload bulk",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "message": "3 dokumen berhasil diupload, 0 gagal",
                    "success": [
                      {
                        "id": 1,
                        "title": "SOP Rekrutmen",
                        "format": "PDF"
                      },
                      {
                        "id": 2,
                        "title": "SOP Cuti Karyawan",
                        "format": "PDF"
                      },
                      {
                        "id": 3,
                        "title": "SOP Kenaikan Gaji",
                        "format": "TXT"
                      }
                    ],
                    "failed": []
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Upload multiple dokumen SOP sekaligus (Admin only)",
        "tags": [
          "SOP Documents"
        ]
      }
    },
